{
  "name": "agentic-control-plane-kit",
  "version": "0.1.0",
  "description": "Reusable starter kit for adding /manage control-plane API to multi-tenant SaaS platforms",
  "main": "kernel/index.ts",
  "types": "kernel/index.ts",
  "exports": {
    ".": {
      "types": "./kernel/index.ts",
      "default": "./kernel/index.ts"
    },
    "./sdk": {
      "types": "./kernel/src/sdk.ts",
      "default": "./kernel/src/sdk.ts"
    },
    "./packs": {
      "types": "./packs/index.ts",
      "default": "./packs/index.ts"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "echelon": "./dist/echelon.mjs"
  },
  "files": [
    "dist/echelon.mjs",
    "cli",
    "kernel",
    "kernel-py",
    "packs",
    "config",
    "examples",
    "spec",
    "installer",
    "*.md",
    "DOCS-INDEX.md"
  ],
  "scripts": {
    "test": "vitest",
    "test:invariants": "vitest tests/invariants.spec.ts",
    "generate:openapi": "tsx scripts/generate-openapi.ts",
    "verify": "tsx scripts/verify.ts",
    "build": "tsc",
    "build:cli": "esbuild cli/echelon.ts --bundle --platform=node --target=node18 --outfile=dist/echelon.mjs --format=esm --packages=external",
    "prepublishOnly": "npm run build:cli",
    "typecheck": "tsc --noEmit",
    "test:conformance": "vitest tests/conformance/conformance.spec.ts",
    "validate:installer": "bash installer/test/validate-installer.sh",
    "validate:installer:django": "bash installer/test/validate-installer.sh django",
    "validate:installer:express": "bash installer/test/validate-installer.sh express",
    "validate:installer:supabase": "bash installer/test/validate-installer.sh supabase"
  },
  "keywords": [
    "control-plane",
    "api",
    "multi-tenant",
    "agentic",
    "management-api"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
