# Supabase (hosted — typical SDR-style repo has no supabase/config.toml)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# After `echelon init`, the installer extends .env.example with KERNEL_ID / governance hints.
# Service role belongs only on the server (Netlify env), never in the browser bundle.
